ORS_API_KEY=replace_with_your_openrouteservice_api_key
ORS_BASE_URL=https://api.openrouteservice.org
ORS_PROFILE=foot-hiking
ORS_REQUEST_TIMEOUT_S=20
ENABLE_REAL_ROUTING=true
ROUTE_CANDIDATE_SEARCH_COUNT=8
ROUTE_DISTANCE_TOLERANCE_RATIO=0.45
ROUTE_MIN_SCORE=0.2
ROUTE_ROUND_TRIP_POINTS=3
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
